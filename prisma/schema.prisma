// Prisma schema - docs/02_domain_model.md, docs/08_database_schema.md 準拠
// MVP 最小スキーマ（段階的に拡張）

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  accountId    String   @unique // 英数字・必須・重複不可。docs/08
  passwordHash String
  name         String   // 必須・重複可。主人公の表示名もこの値を使用。docs/08
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // 通貨（docs/08_database_schema.md）
  gameCurrencyBalance         Int @default(0)
  premiumCurrencyFreeBalance  Int @default(0)
  premiumCurrencyPaidBalance  Int @default(0)

  // 法・年齢・地域
  birthdate   DateTime?
  country    String?
  region     String?

  // アカウント状態
  accountStatus String @default("active")

  // 運用・分析
  lastLoginAt   DateTime?
  firstLoginAt  DateTime?
  lastActiveAt  DateTime? // spec/010_auth §11.6: 直近操作日時。プレイ中人数・管理画面で参照。1分スロットリングで更新。

  // 表示
  locale String?

  // docs/02, 08: 主人公・仲間・メカは Character に統一。主人公は 1 体のみ
  protagonistCharacterId String?   @unique
  protagonistCharacter   Character? @relation("Protagonist", fields: [protagonistCharacterId], references: [id], onDelete: Cascade)
  characters             Character[] @relation("CharacterOwner")

  // spec/030: 仲間雇用可能回数。購入で+1、仲間作成で-1
  companionHireCount Int @default(0)

  // spec/035, docs/018: 工業は単一プール。設置枠数・コスト上限（エリア制廃止）
  industrialMaxSlots Int @default(5)
  industrialMaxCost  Int @default(200)

  currencyTransactions CurrencyTransaction[]
  orders               Order[]
  facilityInstances    FacilityInstance[]
  inventories          UserInventory[]
  chatMessages         ChatMessage[]
  partyPresets         PartyPreset[]
  equipmentInstances   EquipmentInstance[]
  mechaPartInstances   MechaPartInstance[]
  relicInstances       RelicInstance[]
  expeditions          Expedition[]
  userFacilityTypeUnlocks UserFacilityTypeUnlock[]
  userCraftRecipeUnlocks UserCraftRecipeUnlock[]
  userTitleUnlocks       UserTitleUnlock[]
  userQuests UserQuest[]
}

/// docs/054, spec/054_quests: クエストマスタ。ストーリー・研究・一般。
model Quest {
  id                  String   @id @default(cuid())
  code                String   @unique
  questType           String   // story | research | general
  name                String
  description         String?  // 経緯・状況がわかる説明文
  clearReportMessage  String?  // クリア報告時に表示するメッセージ（ストーリー演出用）
  prerequisiteQuestId String?
  prerequisiteQuest    Quest?   @relation("QuestPrerequisite", fields: [prerequisiteQuestId], references: [id], onDelete: SetNull)
  /// 達成条件タイプ: area_clear | enemy_defeat | skill_success_count | equipment_craft 等
  achievementType     String
  /// 達成条件パラメータ。例: { "areaId": "cuid", "count": 1 } | { "enemyId": "cuid", "count": 10 }
  achievementParam    Json
  /// 報酬: 研究ポイント（研究クエストで使用）
  rewardResearchPoint Int      @default(0)
  rewardTitleId       String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  nextQuests Quest[]  @relation("QuestPrerequisite")
  userQuests UserQuest[]
}

/// docs/054: ユーザーごとのクエスト進行。出現＝受注扱い（オート）。
model UserQuest {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  questId     String
  quest       Quest     @relation(fields: [questId], references: [id], onDelete: Cascade)
  state       String    // in_progress | completed
  progress    Int       @default(0)  // 達成条件の現在値（例: エリアクリア回数、撃破数）
  completedAt DateTime?
  /// クリア報告をクエスト画面で確認した日時。null の間は「報告する」でメッセージ表示可能。
  reportAcknowledgedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, questId])
  @@index([userId])
  @@index([questId])
}

/// docs/02_domain_model.md, 08: 主人公・仲間・メカを 1 テーブルで統一。category で判別
model Character {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("CharacterOwner", fields: [userId], references: [id], onDelete: Cascade)

  category String // protagonist / companion / mech

  displayName   String   @default("冒険者")
  iconFilename String?
  description   String?
  protagonistTalentId String? // 主人公専用（仲間・メカでは未使用）

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// キャラレベル。docs/09: レベル＋CAP採用。LvN の CAP は 560 + 60 * (N - 1) を基本とする。
  level Int @default(1)
  /// 累計経験値。docs/048_experience_and_levelup: Lv N に達する累計 = 10*(N-1)*N/2。経験値付与時に level/CAP を更新。
  experiencePoints Int @default(0)

  STR Int @default(10)
  INT Int @default(10)
  VIT Int @default(10)
  WIS Int @default(10)
  DEX Int @default(10)
  AGI Int @default(10)
  LUK Int @default(10)
  CAP Int @default(60)

  protagonistUser User? @relation("Protagonist")
  characterSkills CharacterSkill[]
  tacticSlots     TacticSlot[]
  partyPresetsSlot1 PartyPreset[] @relation("PresetSlot1")
  partyPresetsSlot2 PartyPreset[] @relation("PresetSlot2")
  partyPresetsSlot3 PartyPreset[] @relation("PresetSlot3")
  mechaEquipments   MechaEquipment[]
  characterEquipments CharacterEquipment[]
  characterRelics   CharacterRelic[]

  @@index([userId])
  @@index([userId, category])
}

/// spec/044, 046: メカの装備。1メカあたり各部位1つまで。個体参照（mechaPartInstanceId）を優先し、無い場合は種別のみ（移行用）。
model MechaEquipment {
  id                  String              @id @default(cuid())
  characterId         String              // メカ（category=mech の Character）
  character           Character           @relation(fields: [characterId], references: [id], onDelete: Cascade)
  slot                String              // frame | core | head | rightArm | leftArm | legs
  mechaPartInstanceId String?
  mechaPartInstance   MechaPartInstance?  @relation(fields: [mechaPartInstanceId], references: [id], onDelete: SetNull)
  mechaPartTypeId     String?             // 互換用。mechaPartInstance があれば instance から種別を参照
  mechaPartType       MechaPartType?      @relation(fields: [mechaPartTypeId], references: [id], onDelete: SetNull)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@unique([characterId, slot])
  @@index([characterId])
  @@index([mechaPartTypeId])
  @@index([mechaPartInstanceId])
}

/// spec/039: 作戦室で編集するパーティプリセット。slot1=主人公（固定）、slot2=仲間、slot3=メカ。
model PartyPreset {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String?  // 表示用（例: プリセット1）。null なら「プリセット」＋連番で表示可
  slot1CharacterId String  // 主人公枠（強制出撃）。user.protagonistCharacterId と一致させる
  slot1Character   Character @relation("PresetSlot1", fields: [slot1CharacterId], references: [id], onDelete: Cascade)
  slot2CharacterId String?  // 仲間枠
  slot2Character   Character? @relation("PresetSlot2", fields: [slot2CharacterId], references: [id], onDelete: SetNull)
  slot3CharacterId String?  // メカ枠
  slot3Character   Character? @relation("PresetSlot3", fields: [slot3CharacterId], references: [id], onDelete: SetNull)
  /// 戦闘開始時の列（1=前列, 2=中列, 3=後列）。未設定時は 1
  slot1BattleCol   Int      @default(1)
  slot2BattleCol   Int?     // null なら 1 扱い
  slot3BattleCol   Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expeditions Expedition[]

  @@index([userId])
}

/// spec/039: 作戦スロット（キャラごと・最大10）。主語−条件−行動。
model TacticSlot {
  id              String   @id @default(cuid())
  characterId     String
  character       Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  orderIndex      Int      // 1～10。評価順
  subject         String   // self / any_ally / any_enemy / front_enemy
  conditionKind   String   // hp_below_percent, subject_has_attr_state, 等
  conditionParam  Json?    // 条件種別ごとのパラメータ
  actionType      String   // normal_attack / skill
  skillId         String?  // actionType=skill のとき FK
  skill           Skill?   @relation(fields: [skillId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([characterId, orderIndex])
  @@index([characterId])
  @@index([skillId])
}

/// docs/15: 設備・スキル用タグ。設備は複数タグを持ち、工業スキルは対象タグに一致する設備で効果発動。
model Tag {
  id          String   @id @default(cuid())
  code        String   @unique // 安定参照用（例: water, ore）。増減は将来調整可。
  name        String   // 表示名（例: 水）
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  facilityTypeTags FacilityTypeTag[]
  skills           Skill[]

  @@index([code])
}

/// docs/02, 15, 017, 018: 設備マスタ。kind で資源探索／工業／訓練を区別。cost は設置枠のコスト計算用（spec/035）。
model FacilityType {
  id          String   @id @default(cuid())
  name        String
  kind        String   // resource_exploration | industrial | training（入出力の流れが異なる）
  description String?
  cost        Int      @default(40) // 設置エリアのコスト消費（018 仮数値）
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  facilityTypeTags   FacilityTypeTag[]
  facilityInstances  FacilityInstance[]
  recipes            Recipe[]
  facilityVariants   FacilityVariant[]
  userFacilityTypeUnlocks UserFacilityTypeUnlock[]

  @@unique([name])
  @@index([name])
  @@index([kind])
}

/// spec/047: 型マスタ。1 型 : 1 建設レシピ。基本型は variantCode='base'。
model FacilityVariant {
  id              String   @id @default(cuid())
  facilityTypeId  String
  facilityType    FacilityType @relation(fields: [facilityTypeId], references: [id], onDelete: Cascade)
  variantCode     String   // base | alpha | beta
  name            String?  // 表示名（基本型、α型）
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  constructionInputs FacilityConstructionRecipeInput[]

  @@unique([facilityTypeId, variantCode])
  @@index([facilityTypeId])
}

/// spec/047: 建設レシピ入力。その型で 1 設備建設時に消費する資源。
model FacilityConstructionRecipeInput {
  id                  String   @id @default(cuid())
  facilityVariantId   String
  facilityVariant     FacilityVariant @relation(fields: [facilityVariantId], references: [id], onDelete: Cascade)
  itemId              String
  item                Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  amount              Int      // 1 回の建設で消費する個数
  createdAt           DateTime @default(now())

  @@unique([facilityVariantId, itemId])
  @@index([facilityVariantId])
  @@index([itemId])
}

/// spec/047: 設備種別の解放。研究で解放済みの設備だけ建設可能。
model UserFacilityTypeUnlock {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  facilityTypeId  String
  facilityType    FacilityType @relation(fields: [facilityTypeId], references: [id], onDelete: Cascade)
  createdAt       DateTime     @default(now())

  @@unique([userId, facilityTypeId])
  @@index([userId])
  @@index([facilityTypeId])
}

/// spec/035, docs/018: 設置済み設備。単一プール（エリアなし）。docs/019: lastProducedAt で生産消化時刻。
model FacilityInstance {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  facilityTypeId  String
  facilityType    FacilityType @relation(fields: [facilityTypeId], references: [id], onDelete: Cascade)
  variantCode     String    @default("base") // 017: base | alpha | beta
  displayOrder    Int       @default(0)
  isForced        Boolean   @default(false)  // 強制配置 5 は true（解体・変更不可）
  lastProducedAt  DateTime? // 019: 最終生産消化時刻。NULL なら User.createdAt または createdAt で計算
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([userId, displayOrder])
}

/// docs/019: ユーザーの素材・製品在庫。受け取り時に増減。
model UserInventory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  quantity  Int      @default(0) // 所持数（0 以上）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, itemId])
  @@index([userId])
  @@index([itemId])
}

/// spec/035, 045: 素材・製品マスタ。category で種別（material / consumable / blueprint / skill_book / paid）。
/// spec/049: 探索消耗品は consumableEffect と maxCarryPerExpedition で効果・持ち込み上限を定義。
/// spec/052: category=skill_book のとき skillId で紐づくスキルに対して習得/レベルアップに使用。
model Item {
  id          String   @id @default(cuid())
  code        String   @unique // water, drinkable_water, wheat, flour, portable_ration
  name        String
  category    String   @default("material") // spec/045: material | consumable | blueprint | skill_book | paid
  /// category=skill_book のとき: この分析書で習得/レベルアップできるスキル。spec/052。
  skillId     String?
  skill       Skill?   @relation(fields: [skillId], references: [id], onDelete: SetNull)
  /// category=consumable のとき: { "type": "hp_percent" | "mp_percent", "value": number } 等。docs/027 で拡張一覧化可。
  consumableEffect      Json?
  /// 探索1回あたりの持ち込み上限（個数）。null は対象外または無制限。
  maxCarryPerExpedition  Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  recipeOutputs   Recipe[]        @relation("RecipeOutput")
  recipeInputs    RecipeInput[]
  userInventories UserInventory[]
  facilityConstructionRecipeInputs FacilityConstructionRecipeInput[]
  craftRecipesAsOutput CraftRecipe[]
  craftRecipeInputs    CraftRecipeInput[]

  dropTableEntries DropTableEntry[]
  researchUnlockCosts ResearchUnlockCost[]

  @@index([skillId])
}

/// spec/049: 探索・報酬用ドロップテーブル（エリア別・枠由来別のアイテム候補）。
model DropTable {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  /// base / battle_bonus / skill / strong_enemy（強敵）/ area_lord_special（領域主）など、枠の由来。
  kind      String
  areaId    String?
  area      ExplorationArea? @relation(fields: [areaId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries DropTableEntry[]

  baseForAreas      ExplorationArea[] @relation("BaseDropTable")
  battleForAreas    ExplorationArea[] @relation("BattleDropTable")
  skillForAreas     ExplorationArea[] @relation("SkillDropTable")
  strongEnemyForAreas ExplorationArea[] @relation("StrongEnemyDropTable")
  areaLordForAreas  ExplorationArea[] @relation("AreaLordDropTable")
}

model DropTableEntry {
  id          String    @id @default(cuid())
  dropTableId String
  dropTable   DropTable @relation(fields: [dropTableId], references: [id], onDelete: Cascade)
  itemId      String
  item        Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  /// 1ロールあたりの最小・最大数量。
  minQuantity Int       @default(1)
  maxQuantity Int       @default(1)
  /// ドロップ候補としての重み（整数）。テーブル内での相対確率を表す。
  weight      Int       @default(1)

  @@index([dropTableId])
  @@index([itemId])
}

/// spec/045, 046, docs/053: 装備種別マスタ。クラフトの出力として参照。slot は EQUIPMENT_SLOTS のいずれか。
model EquipmentType {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  slot      String   // main_weapon | sub_weapon | head | body | arm | leg
  /// クラフト時のランダムステ生成用。NULL または不正の場合はクラフト失敗。docs/053。
  statGenConfig Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  equipmentInstances EquipmentInstance[]
  craftRecipesAsOutput CraftRecipe[]
}

/// spec/046: クラフトレシピ。工業設備の Recipe とは別体系。
model CraftRecipe {
  id                      String   @id @default(cuid())
  code                    String   @unique
  name                    String
  outputKind              String   // equipment | mecha_part | item
  outputEquipmentTypeId   String?
  outputEquipmentType     EquipmentType?  @relation(fields: [outputEquipmentTypeId], references: [id], onDelete: SetNull)
  outputMechaPartTypeId   String?
  outputMechaPartType     MechaPartType?  @relation(fields: [outputMechaPartTypeId], references: [id], onDelete: SetNull)
  outputItemId            String?
  outputItem              Item?    @relation(fields: [outputItemId], references: [id], onDelete: SetNull)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  inputs CraftRecipeInput[]
  userCraftRecipeUnlocks UserCraftRecipeUnlock[]

  @@index([outputKind])
}

/// docs/054: 研究グループ。第一弾は「錆びれた森林研究」。次のグループは前提グループの派生型以外を全クリアで解放。
model ResearchGroup {
  id                   String   @id @default(cuid())
  code                 String   @unique
  name                 String
  displayOrder         Int      @default(0)
  prerequisiteGroupId  String?
  prerequisiteGroup    ResearchGroup?  @relation("ResearchGroupPrerequisite", fields: [prerequisiteGroupId], references: [id], onDelete: SetNull)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  nextGroups ResearchGroup[] @relation("ResearchGroupPrerequisite")
  items      ResearchGroupItem[]
}

/// docs/054: グループに属する解放対象。targetType + targetId で設備種別 or クラフトレシピを参照。
model ResearchGroupItem {
  id              String   @id @default(cuid())
  researchGroupId String
  researchGroup   ResearchGroup @relation(fields: [researchGroupId], references: [id], onDelete: Cascade)
  targetType      String   // facility_type | craft_recipe
  targetId        String   // FacilityType.id or CraftRecipe.id
  isVariant       Boolean  @default(false)  // 派生型なら true。グループクリアは「派生型以外」で判定
  displayOrder    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([researchGroupId, targetType, targetId])
  @@index([researchGroupId])
}

/// docs/054: 解放時の消費コスト（アイテム）。targetType + targetId で対象を指定。同一対象に複数アイテム可。
model ResearchUnlockCost {
  id         String @id @default(cuid())
  targetType String // facility_type | craft_recipe
  targetId   String // FacilityType.id or CraftRecipe.id
  itemId     String
  item       Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  amount     Int    // 1 回の解放で消費する個数
  createdAt  DateTime @default(now())

  @@unique([targetType, targetId, itemId])
  @@index([targetType, targetId])
  @@index([itemId])
}

/// docs/054, 046: 研究で解放済みのクラフトレシピ。解放済みのみクラフト一覧に表示する。
model UserCraftRecipeUnlock {
  id             String     @id @default(cuid())
  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  craftRecipeId  String
  craftRecipe    CraftRecipe @relation(fields: [craftRecipeId], references: [id], onDelete: Cascade)
  createdAt      DateTime   @default(now())

  @@unique([userId, craftRecipeId])
  @@index([userId])
  @@index([craftRecipeId])
}

/// spec/055: 称号マスタ。
model Title {
  id                   String   @id @default(cuid())
  code                 String   @unique
  name                 String
  description          String?  // 称号の簡単な説明
  unlockConditionMemo  String?  // 解放条件のメモ（運用用）
  displayOrder         Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  userUnlocks UserTitleUnlock[]

  @@index([displayOrder])
}

/// spec/055: ユーザの称号解放。
model UserTitleUnlock {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  titleId   String
  title     Title    @relation(fields: [titleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, titleId])
  @@index([userId])
  @@index([titleId])
}

/// spec/046: クラフトレシピの入力（消費資源）。
model CraftRecipeInput {
  id             String     @id @default(cuid())
  craftRecipeId  String
  craftRecipe    CraftRecipe @relation(fields: [craftRecipeId], references: [id], onDelete: Cascade)
  itemId         String
  item           Item       @relation(fields: [itemId], references: [id], onDelete: Cascade)
  amount         Int        // 1 回あたりの消費個数
  createdAt      DateTime   @default(now())

  @@unique([craftRecipeId, itemId])
  @@index([craftRecipeId])
  @@index([itemId])
}

/// spec/045, 046: 装備個体。クラフトで 1 個ずつ作成。ステータスは 021 に従い JSON で保持。
model EquipmentInstance {
  id                String         @id @default(cuid())
  userId            String
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  equipmentTypeId   String
  equipmentType     EquipmentType  @relation(fields: [equipmentTypeId], references: [id], onDelete: Cascade)
  /// 戦闘用ステ補正・属性耐性等。021 に従う。{ "physicalAttack": 50, "physicalDefense": 20 } 等。
  stats             Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  characterEquipments CharacterEquipment[]

  @@index([userId])
  @@index([equipmentTypeId])
}

/// spec/045, 046: 主人公・仲間の装着。1 キャラあたり各スロット 1 つまで。
model CharacterEquipment {
  id                  String              @id @default(cuid())
  characterId         String
  character           Character           @relation(fields: [characterId], references: [id], onDelete: Cascade)
  slot                String              // main_weapon | sub_weapon | head | body | arm | leg
  equipmentInstanceId String?
  equipmentInstance   EquipmentInstance?   @relation(fields: [equipmentInstanceId], references: [id], onDelete: SetNull)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@unique([characterId, slot])
  @@index([characterId])
  @@index([equipmentInstanceId])
}

/// spec/051: 遺物型マスタ。鑑定時のグループ（groupCode）で抽選対象を分ける。
model RelicType {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  groupCode   String?  // 鑑定トークンと対応（例: group_a）
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  relicInstances RelicInstance[]
}

/// spec/051: 遺物用パッシブ効果マスタ。表示・戦闘効果は Next で拡張可。
model RelicPassiveEffect {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  relicInstances         RelicInstance[]
  relicGroupPassiveEffects RelicGroupPassiveEffect[]
}

/// spec/051: 遺物グループごとの鑑定設定。groupCode は RelicType.groupCode およびトークン→グループ対応と一致。
model RelicGroupConfig {
  id                  String   @id @default(cuid())
  groupCode           String   @unique // 例: group_a（RelicType.groupCode と一致）
  name                String?  // 表示名（例: グループA）
  statBonus1Min       Int      // ステ補正1 percent の最小
  statBonus1Max       Int      // ステ補正1 percent の最大
  statBonus2Min       Int
  statBonus2Max       Int
  attributeResistMin  Float    // 耐性倍率の最小（0.85 等）
  attributeResistMax  Float
  includeNoEffect     Boolean  @default(true) // 効果なしを抽選プールに含めるか
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  passiveEffects RelicGroupPassiveEffect[]
}

/// spec/051: 遺物グループで抽選対象になるパッシブ効果（多対多）。
model RelicGroupPassiveEffect {
  id                    String   @id @default(cuid())
  relicGroupConfigId    String
  relicGroupConfig      RelicGroupConfig @relation(fields: [relicGroupConfigId], references: [id], onDelete: Cascade)
  relicPassiveEffectId  String
  relicPassiveEffect    RelicPassiveEffect @relation(fields: [relicPassiveEffectId], references: [id], onDelete: Cascade)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([relicGroupConfigId, relicPassiveEffectId])
  @@index([relicGroupConfigId])
  @@index([relicPassiveEffectId])
}

/// spec/051: 遺物個体。ユーザーが所持する1個1行。鑑定で生成。
model RelicInstance {
  id                    String    @id @default(cuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  relicTypeId            String
  relicType              RelicType @relation(fields: [relicTypeId], references: [id], onDelete: Cascade)
  relicPassiveEffectId   String?
  relicPassiveEffect    RelicPassiveEffect? @relation(fields: [relicPassiveEffectId], references: [id], onDelete: SetNull)
  /// 基礎ステ％補正。例: { "stat": "STR", "percent": 5 }
  statBonus1             Json?
  statBonus2             Json?
  /// Phase 10 用。キー=属性コード、値=受けるダメージ倍率。
  attributeResistances   Json?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  characterRelics CharacterRelic[]

  @@index([userId])
  @@index([relicTypeId])
  @@index([relicPassiveEffectId])
}

/// spec/051: キャラの遺物装着。1キャラあたりスロット1～4を1つずつ。
model CharacterRelic {
  id                String         @id @default(cuid())
  characterId       String
  character         Character      @relation(fields: [characterId], references: [id], onDelete: Cascade)
  slot              Int            // 1～4
  relicInstanceId   String?
  relicInstance     RelicInstance? @relation(fields: [relicInstanceId], references: [id], onDelete: SetNull)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@unique([characterId, slot])
  @@index([characterId])
  @@index([relicInstanceId])
}

/// spec/045, 046: メカパーツ個体。クラフトで 1 個ずつ作成。ステータスは 021・044 に従い JSON で保持。
model MechaPartInstance {
  id                String         @id @default(cuid())
  userId            String
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  mechaPartTypeId   String
  mechaPartType     MechaPartType  @relation(fields: [mechaPartTypeId], references: [id], onDelete: Cascade)
  /// 基礎ステ補正等。021・044 に従う。
  stats             Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  mechaEquipments   MechaEquipment[]

  @@index([userId])
  @@index([mechaPartTypeId])
}

/// spec/035, docs/018: 設備種別ごとの生産レシピ。周期・出力を定義。
model Recipe {
  id              String   @id @default(cuid())
  facilityTypeId  String
  facilityType    FacilityType @relation(fields: [facilityTypeId], references: [id], onDelete: Cascade)
  cycleMinutes    Int      // 1 回の生産にかかる分数
  outputItemId    String
  outputItem      Item     @relation("RecipeOutput", fields: [outputItemId], references: [id], onDelete: Cascade)
  outputAmount    Int      // 1 回あたりの出力個数
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  inputs          RecipeInput[]

  @@unique([facilityTypeId])
  @@index([facilityTypeId])
}

/// spec/035: レシピの入力素材。資源探索は 0 件、工業は 1 件以上。
model RecipeInput {
  id        String   @id @default(cuid())
  recipeId  String
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  amount    Int      // 1 回あたりの消費個数
  createdAt DateTime @default(now())

  @@unique([recipeId, itemId])
  @@index([recipeId])
}

/// 設備 ↔ タグ の多対多。docs/15
model FacilityTypeTag {
  id             String       @id @default(cuid())
  facilityTypeId String
  facilityType   FacilityType @relation(fields: [facilityTypeId], references: [id], onDelete: Cascade)
  tagId          String
  tag            Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([facilityTypeId, tagId])
  @@index([facilityTypeId])
  @@index([tagId])
}

/// spec/044, docs/053: メカパーツ種別マスタ。部位ごとの基礎ステ加算とフレーム倍率、紐づくメカスキルを定義。
model MechaPartType {
  id        String   @id @default(cuid())
  slot      String   // frame | core | head | rightArm | leftArm | legs
  name      String

  /// フレーム用の基礎ステ倍率（JSON オブジェクト）。slot=frame のときのみ使用。
  /// 例: { "STR": 1.2, "DEX": 0.8 }。キーが無い基礎ステは 1.0 扱い。
  statRates Json?

  /// クラフト時のランダム基礎ステ生成用。NULL または不正の場合はクラフト失敗。docs/053。
  statGenConfig Json?

  /// フレーム以外の部位用のフラット加算値。NULL は 0 扱い。
  strAdd   Int? @default(0)
  intAdd   Int? @default(0)
  vitAdd   Int? @default(0)
  wisAdd   Int? @default(0)
  dexAdd   Int? @default(0)
  agiAdd   Int? @default(0)
  lukAdd   Int? @default(0)
  capAdd   Int? @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mechaPartTypeSkills MechaPartTypeSkill[]
  mechaEquipments     MechaEquipment[]
  mechaPartInstances  MechaPartInstance[]
  craftRecipesAsOutput CraftRecipe[]
}

/// spec/044: メカパーツ種別 ↔ スキル の多対多。1 パーツ種別に 0 個以上のメカスキルを紐づける。
model MechaPartTypeSkill {
  id              String        @id @default(cuid())
  mechaPartTypeId String
  mechaPartType   MechaPartType @relation(fields: [mechaPartTypeId], references: [id], onDelete: Cascade)
  skillId         String
  skill           Skill         @relation(fields: [skillId], references: [id], onDelete: Cascade)
  orderIndex      Int           @default(0)
  createdAt       DateTime      @default(now())

  @@unique([mechaPartTypeId, skillId])
  @@index([mechaPartTypeId])
  @@index([skillId])
}

/// spec/030, docs/08, 15: スキルマスタ。工業スキルは category=industrial。戦闘スキルは category=battle_active（spec/038）。
model Skill {
  id          String   @id @default(cuid())
  name        String
  category    String   // industrial / battle_active / battle_passive 等
  description String?
  // 表示用タグ（作戦室スキル一覧・ツールチップ用）。docs/14_initial_skills.csv の display_tags から Seed で投入。
  displayTags Json?
  // 工業スキル用。effectType: time_reduction | production_bonus。effectValue: 百分率（5 = 5%）。targetTagId の設備に配備時のみ発動。
  effectType   String?  // time_reduction | production_bonus
  effectValue  Int?     // 例: 5 → 5%
  targetTagId  String?
  targetTag    Tag?      @relation(fields: [targetTagId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // spec/038: 戦闘スキル用（category=battle_active のとき使用）。NULL なら非戦闘スキル。
  battleSkillType      String?   // physical / magic / support
  mpCostCapCoef        Decimal?  // CAP * this + mpCostFlat
  mpCostFlat           Int?
  chargeCycles         Int?      // チャージタイム（サイクル）。0=即時発動
  cooldownCycles       Int?      // クールダウン（サイクル）。使用後Nサイクル再使用不可。0=クールダウンなし（docs/023）
  powerMultiplier      Decimal?  // ダメージ/回復倍率
  hitsMin              Int?      // 攻撃回数 min
  hitsMax              Int?      // 攻撃回数 max
  resampleTargetPerHit Boolean?  // 毎回ターゲット再抽選
  targetScope          String?   // enemy_single / enemy_all / ally_single / ally_all / self
  attribute            String?   // none / crush / slash / pierce / burn / freeze / corrode / polarity
  weightAddFront       Decimal?  // このスキル使用時の列ウェイト加算
  weightAddMid         Decimal?
  weightAddBack        Decimal?
  logMessage           String?   // 戦闘ログ通常文（{敵名}等プレースホルダー可）
  logMessageOnCondition String?  // 条件達成時追加文（UIで色分け）

  characterSkills CharacterSkill[]
  skillEffects    SkillEffect[]
  tacticSlots     TacticSlot[]
  mechaPartTypeSkills MechaPartTypeSkill[]
  enemySkills     EnemySkill[]
  enemyTacticSlots EnemyTacticSlot[]
  /// spec/052: このスキル用のスキル分析書アイテム（Item.category=skill_book）
  skillBookItems  Item[]

  @@unique([name, category])
  @@index([category])
  @@index([targetTagId])
}

/// spec/050: 敵種マスタ。1種類の敵の基礎ステ・デフォルト配置・作戦・使用スキル。
model Enemy {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  iconFilename String?
  description String?

  STR Int
  INT Int
  VIT Int
  WIS Int
  DEX Int
  AGI Int
  LUK Int
  CAP Int

  defaultBattleRow Int  // 1-3
  defaultBattleCol Int  // 1-3

  tacticSlots EnemyTacticSlot[]
  enemySkills EnemySkill[]
  groupEntries EnemyGroupEntry[]

  strongEnemyAreas ExplorationArea[] @relation("StrongEnemyEnemy")
  areaLordAreas    ExplorationArea[] @relation("AreaLordEnemy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// spec/050: 敵の作戦スロット（最大10。spec/039 と同等）
model EnemyTacticSlot {
  id         String @id @default(cuid())
  enemyId    String
  enemy      Enemy  @relation(fields: [enemyId], references: [id], onDelete: Cascade)
  orderIndex Int
  subject    String
  conditionKind String
  conditionParam Json?
  actionType String
  skillId    String?
  skill      Skill? @relation(fields: [skillId], references: [id], onDelete: SetNull)

  @@index([enemyId])
}

/// spec/050: 敵が使用可能なスキル（Skill 共有）
model EnemySkill {
  id      String @id @default(cuid())
  enemyId String
  enemy   Enemy  @relation(fields: [enemyId], references: [id], onDelete: Cascade)
  skillId String
  skill   Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([enemyId, skillId])
  @@index([enemyId])
}

/// spec/050: 雑魚用敵グループ
model EnemyGroup {
  id   String @id @default(cuid())
  code String @unique
  entries EnemyGroupEntry[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// spec/050: グループに属する敵種と重み
model EnemyGroupEntry {
  id            String @id @default(cuid())
  enemyGroupId  String
  enemyGroup    EnemyGroup @relation(fields: [enemyGroupId], references: [id], onDelete: Cascade)
  enemyId       String
  enemy         Enemy  @relation(fields: [enemyId], references: [id], onDelete: Cascade)
  weight        Int    @default(1)

  @@unique([enemyGroupId, enemyId])
  @@index([enemyGroupId])
}

/// spec/038: スキル効果（effectType + param）。1スキルに0個以上。
model SkillEffect {
  id         String   @id @default(cuid())
  skillId    String
  skill      Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  effectType String   // attr_state_trigger_damage, move_target_column, move_self_column 等
  param      Json?    // 効果ごとのパラメータ
  createdAt  DateTime @default(now())

  @@index([skillId])
}

/// spec/030, 052: キャラの習得スキル。仲間は雇用時に工業スキルを1つランダム付与。level はスキル分析書で強化。spec/052。
model CharacterSkill {
  id         String   @id @default(cuid())
  characterId String
  character  Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  skillId    String
  skill      Skill     @relation(fields: [skillId], references: [id], onDelete: Cascade)
  /// スキルレベル。0=習得直後。Lv N→N+1 に (N+1) 冊の分析書で上昇。spec/052。
  level      Int       @default(0)
  createdAt  DateTime @default(now())

  @@unique([characterId, skillId])
  @@index([characterId])
  @@index([skillId])
}

model CurrencyTransaction {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currencyType String   // game / premium_free / premium_paid
  amount       Int      // 正: 増加, 負: 消費
  reason       String?
  referenceType String?
  referenceId   String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([userId, createdAt])
}

model Order {
  id                      String    @id @default(cuid())
  userId                  String
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  externalPaymentId       String?   @unique
  amountPaid              Int       // 支払い金額（実通貨・最小単位）
  premiumCurrencyGranted  Int       // 付与した課金通貨（有償分）
  status                  String    // pending / completed / refunded / failed
  createdAt               DateTime  @default(now())
  completedAt             DateTime?

  @@index([userId])
}

/// spec/037, docs/00, 022: 全体チャット。直近ログのみ保持（永続は最小限）。
model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String   // 本文（spec で最大 500 文字）
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
}

/// spec/049_exploration, docs/020: 探索テーマ（上位概念）。例：錆びれた森林地区。
model ExplorationTheme {
  id          String   @id @default(cuid())
  code        String   @unique        // 安定参照用コード（rust_forest など）
  name        String                 // 表示名
  description String?                // 説明文（任意）
  displayOrder Int    @default(0)    // 一覧表示順
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  areas ExplorationArea[]
}

/// spec/049_exploration, docs/020: 探索エリア（実際に選んで出撃する場所）。
model ExplorationArea {
  id          String   @id @default(cuid())
  themeId     String
  theme       ExplorationTheme @relation(fields: [themeId], references: [id], onDelete: Cascade)

  code        String   @unique        // 安定参照用コード（yuran_paved_road など）
  name        String                 // 表示名（遊覧舗装路跡 等）
  description String?                // 説明

  difficultyRank   Int      @default(1)  // 体感難易度ランク（1,2,3…）
  recommendedLevel Int      @default(1)  // 推奨レベル

  /// ドロップ・イベント頻度設定（docs/020）
  baseDropMin       Int      @default(3)  // 標準ドロップ枠レンジ（下限）
  baseDropMax       Int      @default(5)  // 標準ドロップ枠レンジ（上限）
  baseSkillEventRate Int     @default(25) // 技能イベント基礎発生率（パーセント）
  skillCheckRequiredValue Int @default(80) // 技能判定の必要値（MVP: 全ステ共通。docs/020 の基準値は将来拡張）
  normalBattleCount Int      @default(5)  // 雑魚戦の想定回数（強敵前）

  /// spec/050: 通常戦の雑魚グループ（EnemyGroup.code で参照）
  normalEnemyGroupCode     String?
  /// spec/050: 体数 1/2/3 の出現率（0-100、合計100）
  enemyCount1Rate          Int      @default(34)
  enemyCount2Rate          Int      @default(33)
  enemyCount3Rate          Int      @default(33)
  /// spec/050: 強敵・領域主はエリアに1体ずつ直接紐づけ（優先）。以下は互換用に残す。
  strongEnemyEnemyId       String?
  strongEnemyEnemy         Enemy?   @relation("StrongEnemyEnemy", fields: [strongEnemyEnemyId], references: [id], onDelete: SetNull)
  areaLordEnemyId          String?
  areaLordEnemy            Enemy?   @relation("AreaLordEnemy", fields: [areaLordEnemyId], references: [id], onDelete: SetNull)
  strongEnemyEnemyGroupCode String?  // 非推奨。strongEnemyEnemyId を優先
  areaLordEnemyGroupCode   String?  // 非推奨。areaLordEnemyId を優先
  /// 強敵勝利後の領域主出現率（0～100）。未設定時は 1。
  areaLordAppearanceRate   Int      @default(1)

  /// 枠由来ごとのドロップテーブル紐づけ（報酬 Phase5）
  baseDropTableId          String?
  baseDropTable            DropTable? @relation("BaseDropTable", fields: [baseDropTableId], references: [id], onDelete: SetNull)
  battleDropTableId        String?
  battleDropTable          DropTable? @relation("BattleDropTable", fields: [battleDropTableId], references: [id], onDelete: SetNull)
  skillDropTableId         String?
  skillDropTable           DropTable? @relation("SkillDropTable", fields: [skillDropTableId], references: [id], onDelete: SetNull)
  strongEnemyDropTableId   String?
  strongEnemyDropTable     DropTable? @relation("StrongEnemyDropTable", fields: [strongEnemyDropTableId], references: [id], onDelete: SetNull)
  areaLordDropTableId      String?
  areaLordDropTable        DropTable? @relation("AreaLordDropTable", fields: [areaLordDropTableId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  expeditions Expedition[]

  dropTables DropTable[]

  @@index([themeId])
}

/// spec/049_exploration, docs/020: 1 回の探索出撃（Expedition）の進行・結果。
model Expedition {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  areaId    String
  area      ExplorationArea @relation(fields: [areaId], references: [id], onDelete: Cascade)

  partyPresetId String
  partyPreset   PartyPreset @relation(fields: [partyPresetId], references: [id], onDelete: Cascade)

  state     String   @default("in_progress") // in_progress / ready_to_finish / finished / aborted

  /// 進行状況（docs/020 に準拠。強敵＝旧中ボス、領域主＝旧大ボス）
  remainingNormalBattles Int   @default(0)
  strongEnemyCleared     Boolean @default(false)
  areaLordCleared        Boolean @default(false)
  battleWinCount         Int     @default(0)
  skillSuccessCount      Int     @default(0)

  /// 探索中の HP/MP 状態（キャラごと）。{ characterId: { hp, mp } } のような形式を想定。
  currentHpMp Json?

  /// 探索用消耗品の残数・一時バフ状態など、探索レイヤーに属する状態。
  explorationState Json?

  /// この探索で獲得した経験値の合計（主人公・仲間に同量付与するためのメモ用）。
  totalExpGained Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([areaId])
  @@index([partyPresetId])
  @@index([state])
}

