// Prisma schema - docs/02_domain_model.md, docs/08_database_schema.md 準拠
// MVP 最小スキーマ（段階的に拡張）

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  accountId    String   @unique // 英数字・必須・重複不可。docs/08
  passwordHash String
  name         String   // 必須・重複可。主人公の表示名もこの値を使用。docs/08
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // 通貨（docs/08_database_schema.md）
  gameCurrencyBalance         Int @default(0)
  premiumCurrencyFreeBalance  Int @default(0)
  premiumCurrencyPaidBalance  Int @default(0)

  // 法・年齢・地域
  birthdate   DateTime?
  country    String?
  region     String?

  // アカウント状態
  accountStatus String @default("active")

  // 運用・分析
  lastLoginAt  DateTime?
  firstLoginAt DateTime?

  // 表示
  locale String?

  // docs/02, 08: 主人公・仲間・メカは Character に統一。主人公は 1 体のみ
  protagonistCharacterId String?   @unique
  protagonistCharacter   Character? @relation("Protagonist", fields: [protagonistCharacterId], references: [id], onDelete: Cascade)
  characters             Character[] @relation("CharacterOwner")

  // spec/030: 仲間雇用可能回数。購入で+1、仲間作成で-1
  companionHireCount Int @default(0)

  // spec/035, docs/018: 工業は単一プール。設置枠数・コスト上限（エリア制廃止）
  industrialMaxSlots Int @default(5)
  industrialMaxCost  Int @default(200)

  currencyTransactions CurrencyTransaction[]
  orders               Order[]
  facilityInstances    FacilityInstance[]
  inventories          UserInventory[]
  chatMessages         ChatMessage[]
  partyPresets         PartyPreset[]
}

/// docs/02_domain_model.md, 08: 主人公・仲間・メカを 1 テーブルで統一。category で判別
model Character {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("CharacterOwner", fields: [userId], references: [id], onDelete: Cascade)

  category String // protagonist / companion / mech

  displayName   String   @default("冒険者")
  iconFilename String?
  description   String?
  protagonistTalentId String? // 主人公専用（仲間・メカでは未使用）

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  STR Int @default(10)
  INT Int @default(10)
  VIT Int @default(10)
  WIS Int @default(10)
  DEX Int @default(10)
  AGI Int @default(10)
  LUK Int @default(10)
  CAP Int @default(60)

  protagonistUser User? @relation("Protagonist")
  characterSkills CharacterSkill[]
  tacticSlots     TacticSlot[]
  partyPresetsSlot1 PartyPreset[] @relation("PresetSlot1")
  partyPresetsSlot2 PartyPreset[] @relation("PresetSlot2")
  partyPresetsSlot3 PartyPreset[] @relation("PresetSlot3")

  @@index([userId])
  @@index([userId, category])
}

/// spec/039: 作戦室で編集するパーティプリセット。slot1=主人公（固定）、slot2=仲間、slot3=メカ。
model PartyPreset {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String?  // 表示用（例: プリセット1）。null なら「プリセット」＋連番で表示可
  slot1CharacterId String  // 主人公枠（強制出撃）。user.protagonistCharacterId と一致させる
  slot1Character   Character @relation("PresetSlot1", fields: [slot1CharacterId], references: [id], onDelete: Cascade)
  slot2CharacterId String?  // 仲間枠
  slot2Character   Character? @relation("PresetSlot2", fields: [slot2CharacterId], references: [id], onDelete: SetNull)
  slot3CharacterId String?  // メカ枠
  slot3Character   Character? @relation("PresetSlot3", fields: [slot3CharacterId], references: [id], onDelete: SetNull)
  /// 戦闘開始時の列（1=前列, 2=中列, 3=後列）。未設定時は 1
  slot1BattleCol   Int      @default(1)
  slot2BattleCol   Int?     // null なら 1 扱い
  slot3BattleCol   Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

/// spec/039: 作戦スロット（キャラごと・最大10）。主語−条件−行動。
model TacticSlot {
  id              String   @id @default(cuid())
  characterId     String
  character       Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  orderIndex      Int      // 1～10。評価順
  subject         String   // self / any_ally / any_enemy / front_enemy
  conditionKind   String   // hp_below_percent, subject_has_attr_state, 等
  conditionParam  Json?    // 条件種別ごとのパラメータ
  actionType      String   // normal_attack / skill
  skillId         String?  // actionType=skill のとき FK
  skill           Skill?   @relation(fields: [skillId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([characterId, orderIndex])
  @@index([characterId])
  @@index([skillId])
}

/// docs/15: 設備・スキル用タグ。設備は複数タグを持ち、工業スキルは対象タグに一致する設備で効果発動。
model Tag {
  id          String   @id @default(cuid())
  code        String   @unique // 安定参照用（例: water, ore）。増減は将来調整可。
  name        String   // 表示名（例: 水）
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  facilityTypeTags FacilityTypeTag[]
  skills           Skill[]

  @@index([code])
}

/// docs/02, 15, 017, 018: 設備マスタ。kind で資源探索／工業／訓練を区別。cost は設置枠のコスト計算用（spec/035）。
model FacilityType {
  id          String   @id @default(cuid())
  name        String
  kind        String   // resource_exploration | industrial | training（入出力の流れが異なる）
  description String?
  cost        Int      @default(40) // 設置エリアのコスト消費（018 仮数値）
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  facilityTypeTags FacilityTypeTag[]
  facilityInstances FacilityInstance[]
  recipes          Recipe[]

  @@unique([name])
  @@index([name])
  @@index([kind])
}

/// spec/035, docs/018: 設置済み設備。単一プール（エリアなし）。docs/019: lastProducedAt で生産消化時刻。
model FacilityInstance {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  facilityTypeId  String
  facilityType    FacilityType @relation(fields: [facilityTypeId], references: [id], onDelete: Cascade)
  variantCode     String    @default("base") // 017: base | alpha | beta
  displayOrder    Int       @default(0)
  isForced        Boolean   @default(false)  // 強制配置 5 は true（解体・変更不可）
  lastProducedAt  DateTime? // 019: 最終生産消化時刻。NULL なら User.createdAt または createdAt で計算
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([userId, displayOrder])
}

/// docs/019: ユーザーの素材・製品在庫。受け取り時に増減。
model UserInventory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  quantity  Int      @default(0) // 所持数（0 以上）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, itemId])
  @@index([userId])
  @@index([itemId])
}

/// spec/035: 素材・製品マスタ。水・飲料水・小麦・小麦粉・携帯食料など。希少部品は将来 category で区別。
model Item {
  id          String   @id @default(cuid())
  code        String   @unique // water, drinkable_water, wheat, flour, portable_ration
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  recipeOutputs  Recipe[]       @relation("RecipeOutput")
  recipeInputs  RecipeInput[]
  userInventories UserInventory[]
}

/// spec/035, docs/018: 設備種別ごとの生産レシピ。周期・出力を定義。
model Recipe {
  id              String   @id @default(cuid())
  facilityTypeId  String
  facilityType    FacilityType @relation(fields: [facilityTypeId], references: [id], onDelete: Cascade)
  cycleMinutes    Int      // 1 回の生産にかかる分数
  outputItemId    String
  outputItem      Item     @relation("RecipeOutput", fields: [outputItemId], references: [id], onDelete: Cascade)
  outputAmount    Int      // 1 回あたりの出力個数
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  inputs          RecipeInput[]

  @@unique([facilityTypeId])
  @@index([facilityTypeId])
}

/// spec/035: レシピの入力素材。資源探索は 0 件、工業は 1 件以上。
model RecipeInput {
  id        String   @id @default(cuid())
  recipeId  String
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  amount    Int      // 1 回あたりの消費個数
  createdAt DateTime @default(now())

  @@unique([recipeId, itemId])
  @@index([recipeId])
}

/// 設備 ↔ タグ の多対多。docs/15
model FacilityTypeTag {
  id             String       @id @default(cuid())
  facilityTypeId String
  facilityType   FacilityType @relation(fields: [facilityTypeId], references: [id], onDelete: Cascade)
  tagId          String
  tag            Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([facilityTypeId, tagId])
  @@index([facilityTypeId])
  @@index([tagId])
}

/// spec/030, docs/08, 15: スキルマスタ。工業スキルは category=industrial。戦闘スキルは category=battle_active（spec/038）。
model Skill {
  id          String   @id @default(cuid())
  name        String
  category    String   // industrial / battle_active / battle_passive 等
  description String?
  // 工業スキル用。effectType: time_reduction | production_bonus。effectValue: 百分率（5 = 5%）。targetTagId の設備に配備時のみ発動。
  effectType   String?  // time_reduction | production_bonus
  effectValue  Int?     // 例: 5 → 5%
  targetTagId  String?
  targetTag    Tag?      @relation(fields: [targetTagId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // spec/038: 戦闘スキル用（category=battle_active のとき使用）。NULL なら非戦闘スキル。
  battleSkillType      String?   // physical / magic / support
  mpCostCapCoef        Decimal?  // CAP * this + mpCostFlat
  mpCostFlat           Int?
  chargeCycles         Int?      // 溜めサイクル。0=即時
  cooldownCycles       Int?      // クールタイム。使用後Nサイクル再使用不可。0=CTなし（docs/023）
  powerMultiplier      Decimal?  // ダメージ/回復倍率
  hitsMin              Int?      // 攻撃回数 min
  hitsMax              Int?      // 攻撃回数 max
  resampleTargetPerHit Boolean?  // 毎回ターゲット再抽選
  targetScope          String?   // enemy_single / enemy_all / ally_single / ally_all / self
  attribute            String?   // none / crush / slash / pierce / burn / freeze / corrode / polarity
  weightAddFront       Decimal?  // このスキル使用時の列ウェイト加算
  weightAddMid         Decimal?
  weightAddBack        Decimal?
  logMessage           String?   // 戦闘ログ通常文（{敵名}等プレースホルダー可）
  logMessageOnCondition String?  // 条件達成時追加文（UIで色分け）

  characterSkills CharacterSkill[]
  skillEffects    SkillEffect[]
  tacticSlots     TacticSlot[]

  @@unique([name, category])
  @@index([category])
  @@index([targetTagId])
}

/// spec/038: スキル効果（effectType + param）。1スキルに0個以上。
model SkillEffect {
  id         String   @id @default(cuid())
  skillId    String
  skill      Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  effectType String   // attr_state_trigger_damage, move_target_column, move_self_column 等
  param      Json?    // 効果ごとのパラメータ
  createdAt  DateTime @default(now())

  @@index([skillId])
}

/// spec/030, docs/08: キャラの習得スキル。仲間は雇用時に工業スキルを1つランダム付与。
model CharacterSkill {
  id         String   @id @default(cuid())
  characterId String
  character  Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  skillId    String
  skill      Skill     @relation(fields: [skillId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([characterId, skillId])
  @@index([characterId])
  @@index([skillId])
}

model CurrencyTransaction {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currencyType String   // game / premium_free / premium_paid
  amount       Int      // 正: 増加, 負: 消費
  reason       String?
  referenceType String?
  referenceId   String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([userId, createdAt])
}

model Order {
  id                      String    @id @default(cuid())
  userId                  String
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  externalPaymentId       String?   @unique
  amountPaid              Int       // 支払い金額（実通貨・最小単位）
  premiumCurrencyGranted  Int       // 付与した課金通貨（有償分）
  status                  String    // pending / completed / refunded / failed
  createdAt               DateTime  @default(now())
  completedAt             DateTime?

  @@index([userId])
}

/// spec/037, docs/00, 022: 全体チャット。直近ログのみ保持（永続は最小限）。
model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String   // 本文（spec で最大 500 文字）
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
}
