# Database
# Docker Compose 使用時: docker compose up -d の後に以下を使用
DATABASE_URL="postgresql://remaria:remaria_dev@localhost:5432/remaria"

# Neon / Supabase 使用時は接続文字列を置き換える

# Session (32文字以上のランダム文字列)
SESSION_SECRET="your-32-character-or-longer-secret-key-here"

# 戦闘ログで検証ログを表示する（遺物適用前ダメージ等。本番では未設定で非表示。manage/VERIFICATION_LOG.md 参照）
# NEXT_PUBLIC_SHOW_VERIFICATION_LOG="true"
